scalar DateTime

interface Node {
  id: ID!
}

type PageInfo {
  hasNextPage: Boolean!
  hasPreviousPage: Boolean!
  startCursor: String
  endCursor: String
}

type RoomMember implements Node{
  id: ID!
  name: String!
}

type RoomMemberEdge {
  node: RoomMember!
  cursor: String!
}

type RoomMemberConnection {
  edges: [RoomMemberEdge!]!
  pageInfo: PageInfo!
  totalCount: Int
}

type Query {
  node(id: ID!): Node
}
